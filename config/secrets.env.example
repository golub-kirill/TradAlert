# TradAlert — secrets.env.example
#
# Copy this file to config/secrets.env and fill in real values.
# config/secrets.env is gitignored; this template is committed so cold-start
# users know what env vars the app expects.

# ── Telegram (push alerts; enable via settings.yaml telegram.enabled) ────────
# TG_CHAT_ID must be the NUMERIC chat id (used as the owner allowlist).
TG_CHAT_ID=your_numeric_chat_id_here
TG_BOT_TOKEN=your_bot_token_here

# ── MySQL (required for SQL journaling: scan_runs, backtest_runs, positions) ─
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=tradalert

# ── FRED (Federal Reserve Economic Data) ────────────────────────────────────
# Required when settings.yaml::macro.enabled = true.
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
# IMPORTANT: rotate this key periodically; the codebase has a defensive log
# scrubber (F9-A) but exfiltration via accidental traceback is still possible.
FRED_API_KEY=your_fred_api_key_here

# ── SEC EDGAR (F9-4) ────────────────────────────────────────────────────────
# REAL contact email required by SEC fair-access policy — using a placeholder
# triggers IP bans under load. Format: "Org Name (real-contact@email)".
SEC_USER_AGENT=YourOrg (real@email.com)
